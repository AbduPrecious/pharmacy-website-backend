{
  "kind": "collectionType",
  "collectionName": "job_applications",
  "info": {
    "singularName": "job-application",
    "pluralName": "job-applications",
    "displayName": "JobApplication",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "fullName": {
      "type": "string",
      "required": false
    },
    "gender": {
      "type": "enumeration",
      "enum": [
        "Male",
        "Female",
        "Other"
      ]
    },
    "dateOfBirth": {
      "type": "date",
      "required": false
    },
    "location": {
      "type": "string",
      "required": false
    },
    "phoneNumber": {
      "type": "string",
      "required": false
    },
    "secondaryPhone": {
      "type": "string"
    },
    "email": {
      "type": "email",
      "required": false
    },
    "secondaryEmail": {
      "type": "email"
    },
    "profession": {
      "type": "string",
      "required": false
    },
    "currentJobTitle": {
      "type": "string",
      "required": false
    },
    "yearsExperience": {
      "type": "integer",
      "required": false
    },
    "industry": {
      "type": "enumeration",
      "enum": [
        "Healthcare",
        "Pharmaceutical",
        "Medical Devices",
        "Hospital",
        "Research",
        "Education",
        "Other"
      ],
      "required": false
    },
    "careerLevel": {
      "type": "enumeration",
      "enum": [
        "Entry Level",
        "Junior",
        "Mid-Level",
        "Senior",
        "Manager",
        "Director"
      ]
    },
    "educationLevel": {
      "type": "enumeration",
      "enum": [
        "High School",
        "Diploma",
        "Bachelor's",
        "Master's",
        "PhD",
        "Other"
      ],
      "required": false
    },
    "fieldOfStudy": {
      "type": "string",
      "required": false
    },
    "salaryRange": {
      "type": "enumeration",
      "enum": [
        "ETB 0-5000",
        "ETB 5000-10000",
        "ETB 10000-20000",
        "ETB 20000-30000",
        "ETB 30000-50000",
        "ETB 50000+"
      ],
      "required": false
    },
    "otherLanguages": {
      "type": "boolean",
      "required": false
    },
    "languageExplanation": {
      "type": "blocks"
    },
    "hasRelationship": {
      "type": "boolean",
      "required": true
    },
    "hasRelative": {
      "type": "boolean",
      "required": false
    },
    "cv": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "coverLetter": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "vacancy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::job.job",
      "inversedBy": "job_application"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "New",
        "Reviewing",
        "Interviewed",
        "Rejected",
        "Hired"
      ]
    }
  }
}
